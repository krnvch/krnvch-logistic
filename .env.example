VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_POSTHOG_KEY=your-posthog-project-key
VITE_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project

# Supabase Edge Function secrets (set via: supabase secrets set KEY=value)
# LINEAR_API_KEY=your-linear-api-key
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key  (Mira copilot — never a VITE_ var)
# COPILOT_MODEL=gemini-2.5-flash-lite  (optional override, default gemini-2.5-flash; free-tier quota is per-day PER MODEL)

# Sentry source map upload (build-time only, set in Vercel env — NOT VITE_ vars,
# never exposed to the browser). Create an Organization Auth Token in Sentry:
# Settings → Auth Tokens (sntrys_… tokens embed the region URL, EU included).
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=grida-app
# SENTRY_AUTH_TOKEN=sntrys_your-org-auth-token
